---
import config from 'virtual:starlight/user-config';

import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';

const shouldRenderSearch =
	config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

const navItems = [
	{ label: '首页', href: '/' },
	{ label: '标准作业流程 SOP', href: '/标准作业流程sop/' },
	{ label: '系统对接指南', href: '/系统对接指南/' },
	{ label: '常见问题 FAQ', href: '/常见问题FAQ/' },
	{ label: '系统更新', href: '/系统更新/' },
];

const currentPath = Astro.url.pathname;
const isActive = (href) => (href === '/' ? currentPath === '/' : currentPath.startsWith(href));
---

<div class="header sl-flex">
	<div class="title-wrapper sl-flex">
		<SiteTitle />
	</div>
	<nav class="primary-nav sl-flex sl-hidden md:sl-flex" aria-label="主导航">
		{
			navItems.map((item) => (
				<a
					class:list={['primary-nav-link', { 'is-active': isActive(item.href) }]}
					href={item.href}
					aria-current={isActive(item.href) ? 'page' : undefined}
				>
					{item.label}
				</a>
			))
		}
	</nav>
	<div class="sl-hidden md:sl-flex print:hidden right-group sl-flex">
		{shouldRenderSearch && <Search />}
		<div class="sl-flex social-icons">
			<SocialIcons />
		</div>
		<ThemeSelect />
		<LanguageSelect />
	</div>
</div>

<style>
	.header {
		gap: var(--sl-nav-gap);
		justify-content: space-between;
		align-items: center;
	}

	.title-wrapper {
		/* Prevent long titles overflowing and covering the search and menu buttons on narrow viewports. */
		overflow: clip;
		/* Avoid clipping focus ring around link inside title wrapper. */
		padding: 0.125rem;
		margin: -0.125rem;
		min-width: 0;
		display: flex;
		align-items: center;
	}

	.right-group {
		gap: 0.75rem;
		align-items: center;
	}

	.primary-nav {
		gap: 0.75rem;
		align-items: center;
		white-space: nowrap;
	}

	.primary-nav-link {
		color: inherit;
		text-decoration: none;
		font-size: 11px;
		padding: 0.125rem 0.25rem;
	}

	.primary-nav-link:hover {
		color: var(--sl-color-text);
	}

	.social-icons {
		gap: 0.5rem;
		align-items: center;
		display: flex;
	}
	
	.social-icons::after {
		content: '';
		height: 1.5rem;
		border-inline-end: 1px solid var(--sl-color-gray-5);
	}
</style>
